# PostgreSQL connection
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=myuser
DATABASE_PASSWORD=mypassword
DATABASE_NAME=mydb

# Bearer token for authenticating MCP clients
# Generate a strong random token: openssl rand -hex 32
AUTH_TOKEN=your-secret-token-here

# Server binding
PORT=3000
HOST=0.0.0.0

# Max rows returned by the query tool (protects against runaway queries)
ROW_LIMIT=100

# Google Cloud deployment (used by scripts/deploy.sh)
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=us-central1
GCP_SERVICE_NAME=postgres-mcp
GCP_IMAGE_NAME=postgres-mcp-ts
